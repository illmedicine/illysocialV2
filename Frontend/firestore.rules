rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user IllySocial account (settings, legacy paymentLinks field).
    // Owner-only; nothing here is shown publicly.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Creator profile: onboarding status, integrations, payment links.
    match /creators/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Budgeted campaigns (CoinDrop / Facebook / Kick / Twitch / Instagram)
      // belonging to this creator. Owner-only.
      match /campaigns/{campaignId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Public Creators Corner fanpages — anyone can view a creator's page;
    // only the owning creator (matched via the userId field) can write it.
    match /fanpages/{nickname} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Fan message board on a Creators Corner page — open to fans (no
      // auth required) to post and read; messages are immutable once sent.
      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 1000;
        allow update, delete: if false;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
